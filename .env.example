# ══════════════════════════════════════════════════════════════
# GRAIDER ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# cp .env.example .env
# ══════════════════════════════════════════════════════════════

# OpenAI API Key (Required)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Gmail Configuration (Optional - for email feature)
# 1. Enable 2FA on your Google account
# 2. Go to: Google Account → Security → App Passwords
# 3. Generate a new app password for "Mail"
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Default Paths (Optional - can also set in UI)
ASSIGNMENTS_FOLDER=/path/to/assignments
OUTPUT_FOLDER=/path/to/output
ROSTER_FILE=/path/to/roster.xlsx

# Flask Configuration (Optional)
FLASK_ENV=development
FLASK_DEBUG=1

# Phase 4.1 Celery task queue
CELERY_BROKER_URL=redis://localhost:6379/1

# Phase 4.5 — per-user JWT Supabase clients
# Anon key from Supabase project settings → API → anon public key.
# Same key that's in the frontend; safe to reuse.
SUPABASE_ANON_KEY=<paste-from-supabase-api-settings>

# Flag that controls whether direct-Supabase-JWT teacher requests get a
# per-user Supabase client (RLS-enforced) or the service-role client
# (RLS-bypassing, current behavior). Keep "0" during rollout; flip to
# "1" only after observability data justifies the change. See
# docs/superpowers/specs/2026-04-19-phase4.5-per-user-jwt-design.md
# § Observability bar before flipping.
USE_PER_USER_JWT=0

# ─────────────────────────────────────────────────────────────────
# Alembic migration tooling (Phase 4 follow-on, 2026-04-18)
# ─────────────────────────────────────────────────────────────────
# Postgres connection string used ONLY by the `alembic` CLI (run manually
# by operators before merging PRs that add migrations). Do NOT point this
# at the transaction pooler — Alembic requires session-level connection
# semantics. Use Supabase's session pooler (port 5432). See:
#   docs/superpowers/specs/2026-04-18-alembic-migration-tooling-design.md
ALEMBIC_DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/graider
