# ══════════════════════════════════════════════════════════════
# GRAIDER ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Closes audit MAJOR #18 (Codex 2026-05-06 / issue #219): canonical
# inventory of every env var the runtime reads via os.getenv() /
# os.environ. Sections labeled REQUIRED must be set for the app to
# boot in their respective environments. Keep this file in sync
# with new os.getenv() call sites — diffing against the codebase is
# the source of truth.
# ══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# Core: AI providers (at least ONE required)
# ─────────────────────────────────────────────────────────────────
# OpenAI is the primary grading model. Keys: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Optional fallbacks. Keep blank if unused.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# OpenAI grading model override (default: gpt-4o-mini). Rarely needed.
GRADING_MODEL=

# ─────────────────────────────────────────────────────────────────
# Core: Supabase (REQUIRED for student portal, classes, submissions)
# ─────────────────────────────────────────────────────────────────
# Project URL (Settings → API → Project URL)
SUPABASE_URL=https://<project>.supabase.co

# Service-role key (Settings → API → service_role; KEEP SECRET — bypasses RLS)
SUPABASE_SERVICE_KEY=

# Anon public key (Settings → API → anon; safe to share, used by frontend too)
SUPABASE_ANON_KEY=

# JWT signing secret (Settings → API → JWT Secret; required for token validation)
SUPABASE_JWT_SECRET=

# Phase 4.5 flag — direct-Supabase-JWT teacher requests get a per-user
# Supabase client (RLS-enforced) when set to "1". Keep "0" until
# observability data justifies the flip. See:
#   docs/superpowers/specs/2026-04-19-phase4.5-per-user-jwt-design.md
USE_PER_USER_JWT=0

# ─────────────────────────────────────────────────────────────────
# Flask: REQUIRED in production
# ─────────────────────────────────────────────────────────────────
# Session signing key — MUST be set in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
FLASK_SECRET_KEY=

# "production" hard-requires Redis (see below) and disables debug.
# "development" relaxes both for local dev.
FLASK_ENV=development
FLASK_DEBUG=1

# Sentinel that forces /healthz to return 503 — used by smoke tests
# and SRE drills. Leave UNSET in production.
FORCE_HEALTHZ_FAIL=

# ─────────────────────────────────────────────────────────────────
# Redis: REQUIRED in production
# ─────────────────────────────────────────────────────────────────
# Backs Flask-Limiter rate-limit counters AND Flask-Session storage.
# `backend/extensions.py:19` raises at boot if FLASK_ENV=production
# and Redis is unreachable. Provision via Railway Add-on → Redis or
# any managed Redis 6+ provider. See docs/DEPLOYMENT.md.
REDIS_URL=redis://localhost:6379/0

# Phase 4.1 Celery task queue. Default: same Redis as REDIS_URL
# but on db=1 to keep queue and rate-limit state separate.
CELERY_BROKER_URL=redis://localhost:6379/1

# ─────────────────────────────────────────────────────────────────
# Observability: Sentry (recommended for production)
# ─────────────────────────────────────────────────────────────────
# DSN from sentry.io project settings. When unset, Sentry SDK is
# initialized but never sends events.
SENTRY_DSN=

# APM tracing sample rate (0.0–1.0). Default 0.05 (5%). Set to
# 0.0 to disable transaction sampling without removing the SDK.
SENTRY_TRACES_SAMPLE_RATE=

# Set automatically by Railway — read for Sentry release tagging.
RAILWAY_GIT_COMMIT_SHA=

# ─────────────────────────────────────────────────────────────────
# Email delivery: choose ONE provider (or none for local dev)
# ─────────────────────────────────────────────────────────────────
# Resend (preferred — used in production)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Gmail SMTP (legacy, app-password based; keep for backward compat)
# 1. Enable 2FA on Google account
# 2. Google Account → Security → App Passwords → "Mail"
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Generic admin/dev contact addresses for system notifications.
ADMIN_EMAIL=
DEV_EMAIL=

# ─────────────────────────────────────────────────────────────────
# Voice / TTS (optional — assistant audio replies)
# ─────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
OPENAI_TTS_MODEL=
OPENAI_TTS_VOICE=

# ─────────────────────────────────────────────────────────────────
# OCR: Mathpix (optional — used for handwritten math extraction)
# ─────────────────────────────────────────────────────────────────
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# ─────────────────────────────────────────────────────────────────
# SIS integrations (configure ONE per district, or none)
# ─────────────────────────────────────────────────────────────────
# Clever (https://apps.clever.com/)
CLEVER_CLIENT_ID=
CLEVER_CLIENT_SECRET=
CLEVER_REDIRECT_URI=https://app.graider.live/api/clever/callback
CLEVER_API_VERSION=v3.0
CLEVER_DISTRICT_TOKEN=

# ClassLink (https://launchpad.classlink.com/)
CLASSLINK_CLIENT_ID=
CLASSLINK_CLIENT_SECRET=

# OneRoster (1EdTech)
ONEROSTER_BASE_URL=
ONEROSTER_CLIENT_ID=
ONEROSTER_CLIENT_SECRET=
ONEROSTER_TOKEN_URL=
ONEROSTER_SCHOOL_ID=

# LTI 1.3 (1EdTech)
LTI_TOOL_URL=

# ─────────────────────────────────────────────────────────────────
# Periodic roster sync (cron webhook auth)
# ─────────────────────────────────────────────────────────────────
# Shared secret between the Railway scheduler and the webhook handler.
# Set the SAME value in GitHub Actions secrets for the cron workflow.
PERIODIC_SYNC_SECRET=

# ─────────────────────────────────────────────────────────────────
# Stripe (billing — production)
# ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=

# ─────────────────────────────────────────────────────────────────
# District admin
# ─────────────────────────────────────────────────────────────────
# Initial admin password (optional; can also be set via /district
# first-time setup form). Once a password is set in DB, this var is
# not consulted again — rotate via the in-app change-password flow.
DISTRICT_ADMIN_PASSWORD=

# Public app URL — used in email templates + LTI/SSO callbacks.
APP_URL=https://app.graider.live

# ─────────────────────────────────────────────────────────────────
# Local development conveniences
# ─────────────────────────────────────────────────────────────────
DEV_USER_ID=

# Default folders for local-dev (can also set in UI)
ASSIGNMENTS_FOLDER=
OUTPUT_FOLDER=
ROSTER_FILE=

# ─────────────────────────────────────────────────────────────────
# Alembic migration tooling (Phase 4 follow-on, 2026-04-18)
# ─────────────────────────────────────────────────────────────────
# Postgres connection string used ONLY by the `alembic` CLI (run
# manually by operators before merging PRs that add migrations).
# Do NOT point this at the transaction pooler — Alembic requires
# session-level connection semantics. Use Supabase's session pooler
# (port 5432). See:
#   docs/superpowers/specs/2026-04-18-alembic-migration-tooling-design.md
ALEMBIC_DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/graider
