# ══════════════════════════════════════════════════════════════
# GRAIDER .gitignore
# ══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# SECRETS & CREDENTIALS (CRITICAL - NEVER COMMIT THESE)
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
secrets.json
*_secret.json
*_secret.txt
# Local SQLite DBs + their WAL/SHM/journal sidecars (the bare *.db rule below
# does NOT match the -shm/-wal/-journal sidecars; audit #6 found them committed)
*.db-shm
*.db-wal
*.db-journal
*_credentials.json
*_credentials.txt
.graider_email.json

# API Keys that might be in files
config.local.py
local_settings.py

# ─────────────────────────────────────────────────────────────
# PYTHON
# ─────────────────────────────────────────────────────────────
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Anchor /lib/ and /lib64/ to repo root so we don't sweep up nested
# directories like loadtest/lib/. Distutils only outputs these at the
# root anyway. Caught loadtest/lib/http.js silently in PR #177.
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Virtual environments
venv/
ENV/
env/
.venv/
.ENV/
env.bak/
venv.bak/
pythonenv*/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# ─────────────────────────────────────────────────────────────
# NODE / JAVASCRIPT (for future frontend build)
# ─────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
frontend/dist/
frontend/build/
*.bundle.js
*.bundle.js.map

# Vite
frontend/.vite/

# Next.js (if ever used)
.next/
out/

# ─────────────────────────────────────────────────────────────
# macOS
# ─────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# Icon must end with two \r
Icon

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# ─────────────────────────────────────────────────────────────
# Windows
# ─────────────────────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# ─────────────────────────────────────────────────────────────
# Linux
# ─────────────────────────────────────────────────────────────
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ─────────────────────────────────────────────────────────────
# IDEs & EDITORS
# ─────────────────────────────────────────────────────────────
# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*.swn
*~
.vim/

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ─────────────────────────────────────────────────────────────
# GRAIDER SPECIFIC
# ─────────────────────────────────────────────────────────────
# Output folders (contain graded work - don't commit student data!)
Results/
# ...but the ResultsTab source components are code, not graded output
# (macOS core.ignorecase makes `Results/` also match `results/`):
!frontend/src/tabs/results/
Graded/
Output/
Exports/

# Student data (FERPA compliance - NEVER commit!)
*roster*.xlsx
*roster*.csv
*students*.xlsx
*students*.csv
master_grades.csv
student_emails/

# Allow test fixture files (overrides above ignores)
!tests/fixtures/master_grades.csv
!tests/fixtures/roster_period_*.csv
!tests/load/fixtures/rosters/*.csv

# Uploaded assignments (student work)
Assignments/
Uploads/
*.docx
*.pdf
!templates/*.docx
!templates/*.pdf
# Committed documentation PDFs (generated by docs/*.py, kept in the repo)
!docs/*.pdf

# Checkpoint backup files
*_checkpoint_*.py

# Chrome profile for SharePoint (contains session data)
.graider_chrome_profile/

# Download tracking
.graider_downloads.json

# Lesson plans (might contain student-specific info)
Lesson_Plans/

# Logs
*.log
logs/

# ─────────────────────────────────────────────────────────────
# py2app / Mac App Build
# ─────────────────────────────────────────────────────────────
build/
dist/
*.dmg
*.app/

# ─────────────────────────────────────────────────────────────
# TESTING
# ─────────────────────────────────────────────────────────────
test_output/
test_results/
*.test.js
*.spec.js
!frontend/e2e/*.spec.js
!tests/e2e/specs/*.spec.js
!landing/*.test.js

# ─────────────────────────────────────────────────────────────
# MISC
# ─────────────────────────────────────────────────────────────
# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Archives
*.zip
*.tar.gz
*.rar
*.7z

# Database files
*.db
*.sqlite
*.sqlite3

# Large media files (if any)
*.mp4
*.mov
*.avi
*.mp3
*.wav
.gitnexus
.worktrees/
.superpowers/
test-results/

# Frontend bundle — built at deploy (Railway/NIXPACKS), not committed
/backend/static/
